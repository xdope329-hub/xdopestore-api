# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/xdopestore

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Access token — short-lived (default 15m)
JWT_SECRET=change_me_access_secret
JWT_EXPIRES_IN=15m

# Refresh token — long-lived (default 7d). Must be DIFFERENT from JWT_SECRET.
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the storefront (used to set CORS allow-list)
FRONTEND_URL=http://localhost:3000
# Comma-separated extra origins, e.g. admin dashboard
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# ─── Cloudinary (image uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── MercadoPago (payments) ───────────────────────────────────────────────────
MP_ACCESS_TOKEN=your_mercadopago_access_token
MP_SANDBOX=true

# ─── Storefront URLs (used in payment redirect callbacks) ─────────────────────
STORE_URL=http://localhost:3000
BASE_URL=http://localhost:5000

# ─── Brevo (transactional email + newsletter) ────────────────────────────────
# API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
# From address must be a validated sender in your Brevo account
BREVO_SENDER_EMAIL=no-reply@xdope.com
BREVO_SENDER_NAME=xDope Store
# Numeric ID of the Brevo contact list newsletter subscribers should join
BREVO_NEWSLETTER_LIST_ID=

# ─── Seed script ──────────────────────────────────────────────────────────────
# Default admin user created by `npm run seed`
ADMIN_EMAIL=admin@xdope.com
ADMIN_PASSWORD=Admin1234!

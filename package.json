{
  "name": "xdopestore-api",
  "version": "2.0.0",
  "description": "xdope-store Express.js + MongoDB backend",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node seed/seed.js",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "reset": "node seed/reset.js",
    "seed:e2e": "node -r dotenv/config seed/seed.js dotenv_config_path=.env.e2e",
    "start:e2e": "node -r dotenv/config server.js dotenv_config_path=.env.e2e",
    "reset:e2e": "node -r dotenv/config seed/reset.js dotenv_config_path=.env.e2e"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 60000,
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/_support/"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "method-override": "^3.0.0",
    "mongoose": "^8.3.4",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
